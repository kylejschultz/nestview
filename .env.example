# ── Nestview environment variables ───────────────────────────────────────────
# Copy this file to .env and edit as needed.
# docker compose automatically loads .env from the project root.
# Log retention, container TTL, and all alert settings are configured in the Settings UI.

# Port Nestview is exposed on (default: 8484)
NESTVIEW_PORT=8484

# How often the collector polls Docker for container stats, in seconds (default: 10)
POLL_INTERVAL=10

# How often the collector flushes buffered logs to the backend, in seconds (default: 5)
LOG_BATCH_INTERVAL=5

# Optional: override the auto-generated session signing key.
# Leave blank — Nestview generates and persists one automatically.
SECRET_KEY=

# Set to true to clear stored credentials and re-trigger the setup wizard on next start.
# Remove this line after completing setup.
RESET_ADMIN_PASSWORD=

# Set to true if Nestview is behind a TLS-terminating reverse proxy (Nginx, Caddy, Traefik, etc.)
# Marks session cookies as Secure so they are only sent over HTTPS.
NESTVIEW_SECURE_COOKIES=false

# Path inside the container where Nestview stores its SQLite database (default: /data/nestview.db).
# Override only if you need to point at a non-standard mount path.
DATABASE_PATH=/data/nestview.db

# Timezone used for log timestamps and scheduled tasks (default: UTC).
# Use a standard tz database name, e.g. America/Chicago, Europe/London.
TZ=UTC

# ── Nestview environment variables ───────────────────────────────────────────
# Copy this file to .env and edit as needed.
# docker compose automatically loads .env from the project root.

# Port Nestview is exposed on (default: 8080)
NESTVIEW_PORT=8080

# Optional shared secret between backend and collector.
# Set the same value in both services to reject unauthenticated collector POSTs.
NESTVIEW_COLLECTOR_KEY=

# Discord webhook URL for crash/restart/stop alerts.
# Leave blank to disable alerting.
DISCORD_WEBHOOK_URL=

# How many days of logs and events to retain (default: 7)
LOG_RETENTION_DAYS=7

# Hours after which exited/dead containers are purged from the DB by the
# hourly cleanup job (safety net for when the collector was offline during
# container removal). Set to 0 to disable. Default: 1
EXITED_CONTAINER_TTL_HOURS=1

# How often the collector polls Docker for container stats, in seconds (default: 10)
POLL_INTERVAL=10

# How often the collector flushes buffered logs to the backend, in seconds (default: 5)
LOG_BATCH_INTERVAL=5
